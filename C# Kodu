Random rastgele = new Random();
bool tekrar = true;
int min = 1;
int max = 10;
int tahmin;
int sayi;
int tahminler;
String cevap;

while (tekrar)
{
    tahmin = 0;
    tahminler = 0;
    cevap = "";
    sayi = rastgele.Next(min, max + 1);

    Console.WriteLine(min + " ila " + max + " arasında bir sayı tahmin et ");
    Console.WriteLine();

    while (tahmin != sayi)
    {
        tahmin = Convert.ToInt32(Console.ReadLine());
        Console.WriteLine();
        Console.WriteLine("Tahminin: " + tahmin);

        if (tahmin > sayi)
        {
            Console.WriteLine("Sayı tahmininizden daha küçük!");
            Console.WriteLine();
        }
        else if (tahmin < sayi)
        {
            Console.WriteLine("Sayı tahmininizden daha büyük!");
            Console.WriteLine();
        }
        tahminler++;
    }
    Console.WriteLine("Sayı " + sayi);
    Console.WriteLine();
    Console.WriteLine("Doğru!");
    Console.WriteLine();
    Console.WriteLine("Tahmin etme sayın: " + tahminler);
    if (tahminler > 3)
    {
        Console.WriteLine("Olm senden varya bi bok olmaz he");
    }
    Console.WriteLine("Tekrar oynamak ister misin ? (Evet/Hayır) ");
    Console.WriteLine();
    cevap = Console.ReadLine();
    cevap = cevap.ToUpper();

    if (cevap == "EVET")
    {
        tekrar = true;
    }
    else
    {
        tekrar = false;
        Console.WriteLine("Oynadığın için teşekkürler ");
    }
}
